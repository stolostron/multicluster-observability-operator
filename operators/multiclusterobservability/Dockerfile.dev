# Developer build using publicly available base images.
# Build from the repository root: podman build -f operators/multiclusterobservability/Dockerfile.dev -t <image> .

# Builder always runs on the host platform so Go cross-compilation is native (no emulation).
FROM --platform=$BUILDPLATFORM golang:1.25 AS builder

ARG TARGETOS=linux
ARG TARGETARCH=amd64

WORKDIR /workspace
COPY go.sum go.mod ./
COPY ./operators/multiclusterobservability ./operators/multiclusterobservability
COPY ./operators/pkg ./operators/pkg

RUN --mount=type=cache,target=/go/pkg/mod,sharing=shared \
    --mount=type=cache,target=/root/.cache/go-build,sharing=shared \
    CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -o /usr/local/bin/mco-operator operators/multiclusterobservability/main.go

FROM registry.access.redhat.com/ubi9/ubi-minimal:latest

COPY ./operators/multiclusterobservability/manifests /usr/local/manifests
COPY ./operators/multiclusterobservability/prestop.sh /usr/local/bin/prestop.sh
COPY --from=builder /usr/local/bin/mco-operator /usr/local/bin/mco-operator

EXPOSE 8081 9443

USER 1001:1001
ENTRYPOINT ["/usr/local/bin/mco-operator"]
