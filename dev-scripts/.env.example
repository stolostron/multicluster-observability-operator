# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Variables set here are loaded automatically by all dev-scripts.
# Any variable already set in your shell takes precedence over this file,
# so CLI overrides still work: ACM_VERSION=2.17 ./setup-upstream-catalog.sh

# ---------------------------------------------------------------------------
# quay.io credentials — required for downstream dev builds (add-pull-secret.sh)
# Get your token at: quay.io → Account Settings → CLI Password → Generate Encrypted Password
# ---------------------------------------------------------------------------
QUAY_USER=rh-ee-yourname
QUAY_TOKEN=your-encrypted-cli-token

# ---------------------------------------------------------------------------
# ACM / MCE versions — used by setup-upstream-catalog.sh and setup-downstream-catalog.sh
# ---------------------------------------------------------------------------
ACM_VERSION=2.16
MCE_VERSION=2.11

# ---------------------------------------------------------------------------
# Downstream catalog tags — used by setup-downstream-catalog.sh
# Defaults to latest-<VERSION> when not set.
# Other formats: v2.16.1  or  2.16.1-DOWNSTREAM-2026-03-30-06-49-38
# ---------------------------------------------------------------------------
#ACM_CATALOG_TAG=latest-2.16
#MCE_CATALOG_TAG=latest-2.11

# ---------------------------------------------------------------------------
# Image overrides — used by image-override.sh
# TAG applies to all components built from this repo (see README for the full list).
# REGISTRY defaults to quay.io/stolostron when not set.
# ---------------------------------------------------------------------------
#TAG=2.17.0-SNAPSHOT-2026-04-01-14-59-01
#REGISTRY=quay.io/stolostron
