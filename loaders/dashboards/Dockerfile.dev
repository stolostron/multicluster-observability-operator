# Developer build using publicly available base images.
# Build from the repository root: podman build -f loaders/dashboards/Dockerfile.dev -t <image> .

# Builder always runs on the host platform so Go cross-compilation is native (no emulation).
FROM --platform=$BUILDPLATFORM golang:1.25 AS builder

ARG TARGETOS=linux
ARG TARGETARCH=amd64

WORKDIR /workspace
COPY go.sum go.mod ./
COPY ./loaders/dashboards ./loaders/dashboards

RUN --mount=type=cache,target=/go/pkg/mod,sharing=shared \
    --mount=type=cache,target=/root/.cache/go-build,sharing=shared \
    CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -o /usr/local/bin/grafana-dashboard-loader loaders/dashboards/cmd/main.go

FROM registry.access.redhat.com/ubi9/ubi-minimal:latest

USER 1001:1001

COPY --from=builder /usr/local/bin/grafana-dashboard-loader /usr/local/bin/grafana-dashboard-loader

ENTRYPOINT ["/usr/local/bin/grafana-dashboard-loader"]
